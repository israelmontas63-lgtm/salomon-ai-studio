# Copia este archivo a .env (nunca se sube al repo) y rellena valores reales.
# Render Dashboard → Environment: mismas claves (sync: false).

CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_LANGUAGE=es
CARTESIA_SAMPLE_RATE=44100

# Opcional
TTS_ASYNC=false

# ── SBI-PRO (Speaker Biometric Identity — Israel Monta) ────────────────────
# Generar tokens locales:  python api/sbi/setup_env.py
# Enroll:                  python api/sbi/enroll.py data/seguridad/samples/israel.wav --activar
# Dejar SBI_ENABLED=false hasta completar enrollment con tu voz real.
SBI_ENABLED=false
SBI_MODE=soft
SBI_THRESHOLD=0.82
SBI_OWNER_NAME=Israel Monta
SBI_CHALLENGE_PHRASE=Salomon autentica a Israel
SBI_TEMPLATE_PATH=data/seguridad/sbi_israel.json
SBI_API_BASE=http://127.0.0.1:8000
# Obligatorio para enroll si no usas SALOMON_ADMIN_KEY:
SBI_ENROLL_TOKEN=
# Escape si el micrófono falla (nunca dejes el sistema sin recuperación):
SBI_RECOVERY_KEY=
# Opcional: firma HMAC de la plantilla en disco
SBI_TEMPLATE_SECRET=

# ── Cerebro Ejecutivo (exclusivo Israel Montas) ────────────────────────────
EJECUTIVO_ENABLED=true
# Opcional — lookup telefónico enriquecido (https://numverify.com)
NUMVERIFY_API_KEY=
