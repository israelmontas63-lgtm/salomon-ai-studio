# Copia este archivo a .env (nunca se sube al repo) y rellena valores reales.
# Render Dashboard → Environment: mismas claves.

# ── Cerebro LLM (elige uno; por defecto Gemini) ───────────────────────────
MODEL_PROVIDER=gemini
# Google Gemini (recomendado)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Alternativa OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Alternativa Groq (rápido / gratis)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Seguridad API (opcional; si se define, rutas no públicas piden X-API-Key)
SALOMON_API_KEY=
SALOMON_ADMIN_KEY=
SEGURIDAD_HABILITADA=false

# ── TTS Cartesia ──────────────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_LANGUAGE=es
CARTESIA_SAMPLE_RATE=44100
TTS_ASYNC=false

# ── STT / extras (opcional) ───────────────────────────────────────────────
DEEPGRAM_API_KEY=
TAVILY_API_KEY=
OPENWEATHER_API_KEY=
NUMVERIFY_API_KEY=

# ── SBI-PRO (Speaker Biometric Identity) ──────────────────────────────────
SBI_ENABLED=false
SBI_MODE=soft
SBI_THRESHOLD=0.82
SBI_OWNER_NAME=Israel Monta
SBI_CHALLENGE_PHRASE=Salomon autentica a Israel
SBI_TEMPLATE_PATH=security/credentials/sbi_israel.json
SBI_API_BASE=http://127.0.0.1:8000
SBI_ENROLL_TOKEN=
SBI_RECOVERY_KEY=
SBI_TEMPLATE_SECRET=

# ── Runtime ───────────────────────────────────────────────────────────────
EJECUTIVO_ENABLED=true
BOOT_LIGHT=true
HOST=0.0.0.0
PORT=8000
