# Copia este archivo a .env (nunca se sube al repo) y rellena valores reales.
# Render Dashboard → Environment: mismas claves.
# Backend: FastAPI (app.py). Provider Pattern: config/providers.py

# ── Cerebro LLM (cadena: Gemini → Groq → OpenAI) ─────────────────────────
MODEL_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ───────────────────────────────────────────────────────────
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# ── Audio: STT / TTS ─────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=es
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Multimedia (cadena: Fal → Replicate) ─────────────────────────────────
FAL_KEY=
REPLICATE_API_TOKEN=

# ── TTS respaldo (opcional) ──────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_LANGUAGE=es
CARTESIA_SAMPLE_RATE=44100
TTS_ASYNC=false

# ── Seguridad API (opcional) ─────────────────────────────────────────────
SALOMON_API_KEY=
SALOMON_ADMIN_KEY=
SEGURIDAD_HABILITADA=false

# ── Extras (opcional) ────────────────────────────────────────────────────
TAVILY_API_KEY=
OPENWEATHER_API_KEY=
NUMVERIFY_API_KEY=

# ── SBI-PRO ──────────────────────────────────────────────────────────────
SBI_ENABLED=false
SBI_MODE=soft
SBI_THRESHOLD=0.82
SBI_OWNER_NAME=Israel Monta
SBI_CHALLENGE_PHRASE=Salomon autentica a Israel
SBI_TEMPLATE_PATH=security/credentials/sbi_israel.json
SBI_API_BASE=http://127.0.0.1:8000
SBI_ENROLL_TOKEN=
SBI_RECOVERY_KEY=
SBI_TEMPLATE_SECRET=

# ── Runtime ──────────────────────────────────────────────────────────────
EJECUTIVO_ENABLED=true
BOOT_LIGHT=true
MODO_EJECUCION=true
HOST=0.0.0.0
PORT=8000
