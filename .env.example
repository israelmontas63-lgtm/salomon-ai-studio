# Copia este archivo a .env (nunca se sube al repo) y rellena valores reales.
# Render Dashboard → Environment: mismas claves.
# Backend: FastAPI (app.py). Provider Pattern: config/providers.py

# ── Cerebro LLM (cadena: Gemini → DeepSeek → Groq → OpenAI) ──────────────
MODEL_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ───────────────────────────────────────────────────────────
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# ── Audio: STT / TTS ─────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=es
ELEVENLABS_API_KEY=
# Adam (case-sensitive). Exacto: pNInz6obpgDQGcFmaJgB  (NO pNINz6... / NO ...Gcf...)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Multimedia (cadena: Fal → Replicate) ─────────────────────────────────
FAL_KEY=
REPLICATE_API_TOKEN=

# ── TTS respaldo (opcional; primario = ElevenLabs arriba) ─────────────────
# Si falta CARTESIA_*, el sistema usa solo ElevenLabs (fail-soft).
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_LANGUAGE=es
CARTESIA_SAMPLE_RATE=44100
TTS_ASYNC=false

# ── Seguridad API (opcional) ─────────────────────────────────────────────
SALOMON_API_KEY=
SALOMON_ADMIN_KEY=
SEGURIDAD_HABILITADA=false
# Orígenes CORS explícitos (coma-separados). Vacío → defaults Render+localhost.
CORS_ORIGINS=https://salomon-ai-studio-1.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# ── LLM extendido (cadena) ───────────────────────────────────────────────
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# ── Búsqueda web (cascada: Tavily → Exa → respaldo) ──────────────────────
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
EXA_API_KEY=

# ── Persistencia (Render: montar disco y apuntar DATA_DIR al mount) ───────
# DATA_DIR=/var/data
# SESIONES_DB=/var/data/sesiones.db
# MEMORIA_DIR=/var/data/memoria_chroma

# ── Extras (opcional) ────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
NUMVERIFY_API_KEY=

# ── SBI-PRO ──────────────────────────────────────────────────────────────
SBI_ENABLED=false
SBI_MODE=soft
SBI_THRESHOLD=0.82
SBI_OWNER_NAME=Israel Monta
SBI_CHALLENGE_PHRASE=Salomon autentica a Israel
SBI_TEMPLATE_PATH=security/credentials/sbi_israel.json
SBI_API_BASE=http://127.0.0.1:8000
SBI_ENROLL_TOKEN=
SBI_RECOVERY_KEY=
SBI_TEMPLATE_SECRET=

# ── Runtime ──────────────────────────────────────────────────────────────
EJECUTIVO_ENABLED=true
BOOT_LIGHT=true
MODO_EJECUCION=true
HOST=0.0.0.0
PORT=8000
