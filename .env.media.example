# Plantilla — Colsub Multi-Model Media (Pro/Ultra)
# Copia estas variables a tu .env real y rellena las claves.
# Nunca commitees valores reales.

MEDIA_FORZAR_PRO=true
MEDIA_CALIDAD_FORZADA=pro_ultra
MEDIA_PREFER_IMAGEN=flux
MEDIA_PREFER_VIDEO=runway

FLUX_API_KEY=
FLUX_API_URL=https://fal.run/fal-ai/flux-pro
FLUX_MODEL=flux-1-pro

MIDJOURNEY_API_KEY=
MIDJOURNEY_API_URL=

RUNWAY_API_KEY=
RUNWAY_API_URL=https://api.dev.runwayml.com/v1
RUNWAY_MODEL=gen3a_alpha
RUNWAY_MODEL_PRO=gen3a_alpha

KLING_API_KEY=
KLING_API_URL=
KLING_MODEL=kling-v1-pro

KREA_API_KEY=
KREA_API_URL=
